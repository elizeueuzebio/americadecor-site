{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; frame-src 'none'; img-src 'self' data: https://www.googletagmanager.com https://www.google.com https://www.google.com.br https://www.googleadservices.com https://googleads.g.doubleclick.net https://www.google-analytics.com https://region1.google-analytics.com https:; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; script-src-elem 'self' 'unsafe-inline' https://www.googletagmanager.com; script-src-attr 'none'; style-src 'self'; font-src 'self' data:; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://region1.google-analytics.com https://www.googleadservices.com https://googleads.g.doubleclick.net; media-src 'self'; manifest-src 'self'; object-src 'none'; upgrade-insecure-requests"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=(), autoplay=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "persianasamericadecor.com.br"
        }
      ],
      "destination": "https://www.americadecor.com.br/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.persianasamericadecor.com.br"
        }
      ],
      "destination": "https://www.americadecor.com.br/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "americadecor.com.br"
        }
      ],
      "destination": "https://www.americadecor.com.br/:path*",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "p"
        }
      ],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/automacao.html",
      "destination": "/automacao",
      "permanent": true
    },
    {
      "source": "/contato.html",
      "destination": "/contato",
      "permanent": true
    },
    {
      "source": "/manutencao.html",
      "destination": "/manutencao",
      "permanent": true
    },
    {
      "source": "/persianas-sob-medida.html",
      "destination": "/persianas-sob-medida",
      "permanent": true
    },
    {
      "source": "/persiana-rolo.html",
      "destination": "/persiana-rolo",
      "permanent": true
    },
    {
      "source": "/persiana-double-vision.html",
      "destination": "/persiana-double-vision",
      "permanent": true
    },
    {
      "source": "/persiana-silhouette.html",
      "destination": "/persiana-silhouette",
      "permanent": true
    },
    {
      "source": "/projetos.html",
      "destination": "/projetos",
      "permanent": true
    },
    {
      "source": "/sobre.html",
      "destination": "/sobre",
      "permanent": true
    }
  ]
}
